# Database
DATABASE_URL=postgresql://user:password@host:5432/ink37

# Better Auth
BETTER_AUTH_SECRET=your-secret-key-at-least-32-characters-long
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cal.com Booking
CAL_API_KEY=cal_xxx
NEXT_PUBLIC_CAL_USERNAME=your-cal-username
NEXT_PUBLIC_CAL_CONSULTATION_SLUG=consultation
NEXT_PUBLIC_CAL_DESIGN_REVIEW_SLUG=design-review
NEXT_PUBLIC_CAL_TATTOO_SESSION_SLUG=tattoo-session
NEXT_PUBLIC_CAL_TOUCH_UP_SLUG=touch-up

# Email (Resend)
RESEND_API_KEY=re_xxx
ADMIN_EMAIL=admin@ink37tattoos.com

# Storage (Vercel Blob)
VERCEL_BLOB_READ_WRITE_TOKEN=vercel_blob_xxx
BLOB_PRIVATE_READ_WRITE_TOKEN=vercel_blob_xxx

# Upstash Redis (Rate Limiting)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx...

# Cron Jobs
CRON_SECRET=your-cron-secret-key

# Notification Retention Policy (days)
# Read notifications are deleted after this many days
NOTIFICATION_RETENTION_READ_DAYS=30
# Unread notifications are deleted after this many days (longer to prevent missed alerts)
NOTIFICATION_RETENTION_UNREAD_DAYS=90
# Max notifications to delete per run (prevents table lock contention)
NOTIFICATION_CLEANUP_BATCH_SIZE=1000
