# ===================================================================
# Ink 37 Tattoos - Production Environment Variables
# ===================================================================
# Copy this file to .env.production.local and fill in real values.
# All "Required" variables must be set for the app to function.
# ===================================================================

# === Required ===

# Neon PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/ink37_production

# Better Auth configuration (generate a random 64+ char string for the secret)
BETTER_AUTH_SECRET=generate-a-64-char-random-string
BETTER_AUTH_URL=https://ink37tattoos.com

# Public app URL (used for metadata, sitemap, OG tags)
NEXT_PUBLIC_APP_URL=https://ink37tattoos.com

# === Email (Required for contact form) ===

# Resend API key for transactional emails
RESEND_API_KEY=re_xxx

# Admin email for contact form notifications
ADMIN_EMAIL=admin@ink37tattoos.com

# === Cal.com Booking ===

# Cal.com username and event type slugs for booking embed
NEXT_PUBLIC_CAL_USERNAME=your-cal-username
NEXT_PUBLIC_CAL_CONSULTATION_SLUG=consultation
NEXT_PUBLIC_CAL_DESIGN_REVIEW_SLUG=design-review
NEXT_PUBLIC_CAL_TATTOO_SESSION_SLUG=tattoo-session
NEXT_PUBLIC_CAL_TOUCH_UP_SLUG=touch-up

# === Storage (Required for media uploads) ===

# Vercel Blob storage token for image/video uploads
BLOB_READ_WRITE_TOKEN=vercel_blob_xxx

# === Optional ===

# Cal.com API key for server-side integration (webhooks, sync)
CAL_API_KEY=cal_xxx
